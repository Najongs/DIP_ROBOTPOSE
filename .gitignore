# ============================================================
# DIP monorepo — track code/docs/configs only.
# Datasets, captures, model weights, and training outputs stay
# out of git (history of old per-project repos lives on GitHub).
# ============================================================

# Data hubs (NAS is the only copy — never tracked)
datasets/
1_capture/DGIST_IROM_Data_collection/

# Vendored external clones (have their own .git, re-clonable)
4_perception/DINOv3_fine_tunning/dinov3/
4_perception/DINOv3_fine_tunning/Depth-Anything-3/
dinov3/
DINOv3/

# Model weights / archives / media (data, not code)
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.zip
*.tar.gz
*.gz
*.jsonl
*.json
*.jpg
*.jpeg
*.png
*.webm
*.csv
*.tiff

# Training / evaluation outputs (regenerable)
wandb/
outputs/
outputs_*/
eval_outputs*/
*_inference_results/
inference_output/
network_inference_output/
real_inference_output/
results/
results_*/
runs/
model_save/
integrated_test_results*/

# Keep dependency/config files trackable
!requirements.txt

# Editors / tools
.vscode/
.idea/
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
develop-eggs/
.eggs/
wheels/
MANIFEST
.installed.cfg

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Environments
.env
.envrc
.venv
env/
venv/
ENV/

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Logs / misc
*.log
pip-log.txt
celerybeat-schedule
celerybeat.pid
_assets_src/
3_pose_models/DINObotPose3/Eval/ablation_logs/*.log
3_pose_models/DINObotPose3/Eval/ablation_logs/*.tsv
3_pose_models/DINObotPose3/Eval/ablation_logs/*.lock
